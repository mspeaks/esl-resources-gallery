# Required: Google Gemini API key for AI-powered metadata extraction on PDF upload
# Get one at https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Admin account seeded on first run (leave ESL_ADMIN_PASS empty to skip)
ESL_ADMIN_USER=admin
ESL_ADMIN_PASS=changeme123

# CORS origins (comma-separated) — set to your frontend URL
ESL_CORS_ORIGINS=http://localhost:8080

# Optional: override default paths
# ESL_DB_PATH=./gallery.db
# ESL_PDF_DIR=./media/pdf
# ESL_IMG_DIR=./media/img
# ESL_SESSION_DAYS=30
